{
  "name": "@nbaglivo/ctx",
  "version": "0.1.2",
  "description": "Build curated markdown context files from tagged notes",
  "author": "Nicolas Baglivo <nicolas.baglivo@gmail.com>",
  "type": "module",
  "bin": {
    "ctx": "./dist/index.js"
  },
  "files": [
    "dist",
    "logo"
  ],
  "repository": {
